.group-table td:first-child { text-align: left; padding-left: 14px; font-weight: 500; }
.group-table tr:last-child td { border-bottom: none; }
.group-table tr.qualified td:first-child {
  border-left: 3px solid var(--color-success, #36b37e);
}
.group-table tr.possible td:first-child {
  border-left: 3px solid var(--color-warning, #ff991f);
