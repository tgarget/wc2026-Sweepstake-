// Flag URL helper
function flagImg(code) {
  const c = code || 'un';
  return `<img class="team-flag" src="https://flagcdn.com/24x18/${c}.png" alt="${c}">`;
}

// Render groups
function renderGroups() {
  const grid = document.getElementById('groups-grid');
  grid.innerHTML = '';
  Object.entries(groups).forEach(([letter, group]) => {
    const card = document.createElement('div');
    card.className = 'group-card';
    let hostBadge = group.host ? `<span class="badge">${group.host}</span>` : '';
    let rows = group.teams.map(t => {
      const statusClass = t.status === 'q' ? 'qualified' : t.status === 'p' ? 'possible' : t.status === 'e' ? 'eliminated' : '';
      const owner = sweepstake[t.name] ? `<span class="sweepstake-name">(${sweepstake[t.name]})</span>` : '';
      return `<tr class="${statusClass}">
        <td><div class="team-name">${flagImg(t.code)} ${t.name} ${owner}</div></td>
        <td>${t.pld}</td><td>${t.w}</td><td>${t.d}</td><td>${t.l}</td>
        <td>${t.gf}</td><td>${t.ga}</td><td style="font-weight:600">${t.gd > 0 ? '+' : ''}${t.gd}</td>
        <td style="font-weight:700">${t.pts}</td>
      </tr>`;
    }).join('');

    card.innerHTML = `
      <div class="group-header">Group ${letter} ${hostBadge}</div>
      <table class="group-table">
        <tr><th>Team</th><th>P</th><th>W</th><th>D</th><th>L</th><th>GF</th><th>GA</th><th>GD</th><th>Pts</th></tr>
        ${rows}
      </table>
    `;
    grid.appendChild(card);
  });
}

// Render matches
function renderMatches(filter) {
  const list = document.getElementById('matches-list');
  list.innerHTML = '';
  const filtered = filter === 'All' ? matches : matches.filter(m => m.group === filter);
  let lastDate = '';
  filtered.forEach(m => {
    if (m.date !== lastDate) {
      lastDate = m.date;
      list.innerHTML += `<div class="match-day-header">${m.date}, 2026</div>`;
    }
    const played = m.score !== '—';
    const homeOwner = sweepstake[m.home] ? `<span class="sweepstake-name">(${sweepstake[m.home]})</span>` : '';
    const awayOwner = sweepstake[m.away] ? `<span class="sweepstake-name">(${sweepstake[m.away]})</span>` : '';
    list.innerHTML += `
      <div class="match-card">
        <div class="match-team">${flagImg(getCode(m.home))} ${m.home} ${homeOwner}</div>
        <div class="match-score ${played ? 'played' : ''}">${m.score}</div>
        <div class="match-team right">${m.away} ${awayOwner} ${flagImg(getCode(m.away))}</div>
        <div class="match-venue"><i class="fa-solid fa-location-dot"></i> ${m.venue} • Group ${m.group}</div>
      </div>
    `;
  });
}

