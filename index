.group-card {
  background: var(--color-bg-secondary, #ffffff);
  border: 1px solid var(--color-border-light, #ebecf0);
  border-radius: 8px;
  overflow: hidden;
  overflow-x: auto;
}
.group-header {
  padding: 10px 14px;
