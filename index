// Search / highlight functionality
let currentSearch = '';

function highlightGroups(query) {
  document.querySelectorAll('.group-card').forEach(card => {
    card.classList.remove('has-match');
    card.querySelectorAll('.team-highlight').forEach(el => {
      el.outerHTML = el.textContent;
    });
    if (query) {
      card.querySelectorAll('.team-name').forEach(tn => {
        const text = tn.textContent.trim();
        if (text.toLowerCase().includes(query)) {
          card.classList.add('has-match');
          // Wrap the matching text
          const span = tn.querySelector('span') || tn.childNodes[tn.childNodes.length - 1];
          if (span && span.nodeType === 3) {
            const re = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
            const wrapper = document.createElement('span');
            wrapper.innerHTML = span.textContent.replace(re, '<span class="team-highlight">$1</span>');
            span.parentNode.replaceChild(wrapper, span);
          }
        }
      });
    }
  });
}

function highlightMatches(query) {
  document.querySelectorAll('.match-card').forEach(card => {
    card.classList.remove('has-match');
    if (query) {
      const teams = card.querySelectorAll('.match-team');
      teams.forEach(t => {
        if (t.textContent.toLowerCase().includes(query)) {
          card.classList.add('has-match');
        }
      });
    }
  });
}

function highlightBracket(query) {
  document.querySelectorAll('.bracket-match').forEach(card => {
    card.style.boxShadow = '';
    if (query) {
      const teams = card.querySelectorAll('.bm-team span:first-child');
      teams.forEach(t => {
        if (t.textContent.toLowerCase().includes(query)) {
          card.style.boxShadow = '0 0 0 2px var(--color-primary, #0052CC)';
        }
      });
    }
  });
}

function doSearch(query) {
  currentSearch = query.toLowerCase().trim();
  highlightGroups(currentSearch);
  highlightMatches(currentSearch);
  highlightBracket(currentSearch);
}

document.getElementById('team-search').addEventListener('input', function() {
  doSearch(this.value);
});

